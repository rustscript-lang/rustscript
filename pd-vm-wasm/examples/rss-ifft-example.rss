use math;

use json;

fn nearly_equal(lhs, rhs) {
    math::abs(lhs - rhs) < 0.000001
}

fn nearly_zero(value) {
    nearly_equal(value, 0.0)
}

fn clean(value) {
    let mut out = value;
    if nearly_zero(value) {
        out = 0.0;
    }
    out
}

// A 4-point inverse DFT using the same spectrum as the native IFFT example.
let spectrum_re = [10.0, -2.0, -2.0, -2.0];
let spectrum_im = [0.0, 2.0, 0.0, -2.0];
let re0 = spectrum_re[0];
let re1 = spectrum_re[1];
let re2 = spectrum_re[2];
let re3 = spectrum_re[3];
let im0 = spectrum_im[0];
let im1 = spectrum_im[1];
let im2 = spectrum_im[2];
let im3 = spectrum_im[3];

let quarter_turn = math::pi() / 2.0;
let half_turn = math::pi();
let three_quarter_turn = quarter_turn * 3.0;

let sample0 = clean((re0 + re1 + re2 + re3) / 4.0);
let sample1 = clean(
    (
        re0 +(re1 * math::cos(quarter_turn) - im1 * math::sin(quarter_turn)) +(re2 * math::cos(half_turn) - im2 * math::sin(half_turn)) +(re3 * math::cos(three_quarter_turn) - im3 * math::sin(three_quarter_turn))
    ) / 4.0
);
let sample2 = clean(
    (
        re0 +(re1 * math::cos(half_turn) - im1 * math::sin(half_turn)) + re2 +(re3 * math::cos(half_turn) - im3 * math::sin(half_turn))
    ) / 4.0
);
let sample3 = clean(
    (
        re0 +(re1 * math::cos(three_quarter_turn) - im1 * math::sin(three_quarter_turn)) +(re2 * math::cos(half_turn) - im2 * math::sin(half_turn)) +(re3 * math::cos(quarter_turn) - im3 * math::sin(quarter_turn))
    ) / 4.0
);

let imag0 = clean((im0 + im1 + im2 + im3) / 4.0);
let imag1 = clean(
    (
        im0 +(re1 * math::sin(quarter_turn) + im1 * math::cos(quarter_turn)) +(re2 * math::sin(half_turn) + im2 * math::cos(half_turn)) +(re3 * math::sin(three_quarter_turn) + im3 * math::cos(three_quarter_turn))
    ) / 4.0
);
let imag2 = clean(
    (
        im0 +(re1 * math::sin(half_turn) + im1 * math::cos(half_turn)) + im2 +(re3 * math::sin(half_turn) + im3 * math::cos(half_turn))
    ) / 4.0
);
let imag3 = clean(
    (
        im0 +(re1 * math::sin(three_quarter_turn) + im1 * math::cos(three_quarter_turn)) +(re2 * math::sin(half_turn) + im2 * math::cos(half_turn)) +(re3 * math::sin(quarter_turn) + im3 * math::cos(quarter_turn))
    ) / 4.0
);

assert(nearly_equal(sample0, 1.0));
assert(nearly_equal(sample1, 2.0));
assert(nearly_equal(sample2, 3.0));
assert(nearly_equal(sample3, 4.0));

assert(nearly_zero(imag0));
assert(nearly_zero(imag1));
assert(nearly_zero(imag2));
assert(nearly_zero(imag3));

let summary = {
    samples: [
        math::round(sample0),
        math::round(sample1),
        math::round(sample2),
        math::round(sample3)
    ],
    imag_zero: [
        nearly_zero(imag0),
        nearly_zero(imag1),
        nearly_zero(imag2),
        nearly_zero(imag3)
    ],
    total_signal: sample0 + sample1 + sample2 + sample3
};

print(json::encode(summary));
