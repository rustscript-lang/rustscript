use stdlib::rss::collections as collections;
use stdlib::rss::iter as iter;

use json;

let unique_channels: [string] =
collections::dedup::<string>(["world", "tech", "finance", "culture", "world"]);
let unique_channel_count = unique_channels.length;
assert(unique_channels.length == 4);
assert(unique_channels[0] == "world");
assert(unique_channels[1] == "tech");
assert(unique_channels[2] == "finance");
assert(unique_channels[3] == "culture");
assert(iter::range(unique_channel_count)[0] == 0);
assert(iter::range(unique_channel_count)[3] == 3);
assert(iter::range_step(1, 8, 2)[0] == 1);
assert(iter::range_step(1, 8, 2)[3] == 7);

let scheduled_rows: [[string]] = iter::zip::<string, string>(
    ["00:00", "00:05", "00:10", "00:15"],
    ["world", "tech", "finance", "culture"]
);
assert(scheduled_rows.length == 4);
assert(((&scheduled_rows)[0])[0] == "00:00");
assert(((&scheduled_rows)[0])[1] == "world");

let scheduled_preview: [[string]] = iter::take::<[string]>(&scheduled_rows, 2);
let scheduled_preview_count = scheduled_preview.length;
assert(scheduled_preview_count == 2);

let backlog: [string] = iter::skip::<string>(["world", "tech", "finance", "culture"], 2);
let backlog_count = backlog.length;
assert(backlog.length == 2);
assert(backlog[0] == "finance");
assert(backlog[1] == "culture");

let slot_batches: [[string]] = iter::chunk::<string>(["00:00", "00:05", "00:10", "00:15"], 2);
let slot_batch_count = slot_batches.length;
assert(slot_batch_count == 2);

let channel_label_count = iter::enumerate::<string>(["world", "tech", "finance", "culture"]).length;
assert(channel_label_count == unique_channel_count);

let traffic_windows = [120, 95, 140, 65];
let total_hits: number = iter::sum(&traffic_windows);
assert(total_hits == 420);

let hot_windows: [int] = iter::filter::<int>(&traffic_windows, |value| value >= 100);
let hot_window_count = hot_windows.length;
assert(hot_window_count == 2);

let retry_budget: int = iter::reduce::<int, int>([1, 2, 3, 4], 0, |acc, value| acc + value);
assert(retry_budget == 10);

let long_name_flags: [bool] =
iter::map::<string, bool>(["world", "tech", "finance", "culture"], |name| name.length > 4);
assert(iter::any_true(&long_name_flags));
assert(iter::all_true([true, true]));

let merged_config: map<string> = collections::merge::<string>(
    {interval: "5m", retries: "2", mode: "steady"},
    {retries: "4", mode: "burst"}
);
let config_mode: string = collections::get_or::<string, string>(
    &merged_config,
    "mode",
    "missing"
);
assert(collections::has::<string, string>(&merged_config, "interval"));
assert(config_mode == "burst");
assert(collections::get_or::<string, string>(&merged_config, "missing", "fallback") == "fallback");

let config_entry_count = collections::entries::<string, string>(&merged_config).length;
let config_value_count = collections::values::<string>(&merged_config).length;
assert(config_entry_count == 3);
assert(config_value_count == 3);

let reversed_preview: [string] = collections::reverse::<string>(["world", "finance"]);
let combined_names: [string] = reversed_preview + ["archive"];
assert(collections::index_of::<string>(&combined_names, "archive") == 2);
assert(collections::contains::<string>(&combined_names, "world"));
assert(collections::contains::<string>(combined_names, "sports") == false);

let summary = {
    unique_channel_count: unique_channel_count,
    scheduled_preview_count: scheduled_preview_count,
    backlog_count: backlog_count,
    slot_batch_count: slot_batch_count,
    hot_window_count: hot_window_count,
    retry_budget: retry_budget,
    total_hits: total_hits,
    config_mode: config_mode,
    config_entry_count: config_entry_count,
    config_value_count: config_value_count
};

print(json::encode(summary));
