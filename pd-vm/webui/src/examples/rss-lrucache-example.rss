use json;
use re;

// LRU cache helpers implemented in pure RustScript.
//
// The live set uses:
// - `lookup`: user key -> node id
// - `nodes`: node id -> LruNode
//
// Node ids start at 1. The cache uses `0` as the internal "no link" sentinel,
// because storing `null` into a map entry now deletes that entry.
struct FeedCacheItem {
    day: string,
    topic: string,
    article_count: int,
    slug: string
}

struct LruNode {
    key: string,
    value: FeedCacheItem,
    prev: int,
    next: int
}

struct LinkState {
    nodes: map,
    head: int,
    tail: int
}

struct LruCacheState {
    capacity: int,
    size: int,
    next_id: int,
    head: int,
    tail: int,
    lookup: map,
    nodes: map
}

struct FeedCachePeek {
    found: bool,
    value: FeedCacheItem
}

struct FeedCacheHit {
    cache: LruCacheState,
    found: bool,
    value: FeedCacheItem
}

struct FeedCacheEntry {
    found: bool,
    key: string,
    value: FeedCacheItem
}

struct FeedCacheRow {
    key: string,
    value: FeedCacheItem
}

fn normalized_capacity(raw_capacity) {
    let out = if raw_capacity > 0 => {
        raw_capacity
    } else => {
        0
    };
    out
}

fn empty_feed_item() {
    let out: FeedCacheItem = {
        day: "",
        topic: "",
        article_count: 0,
        slug: ""
    };
    out
}

fn make_cache(limit, size, next_id, head, tail, lookup, nodes) {
    let out: LruCacheState = {
        capacity: limit,
        size: size,
        next_id: next_id,
        head: head,
        tail: tail,
        lookup: lookup,
        nodes: nodes
    };
    out
}

fn append_existing_node(nodes, head, tail, id, node) {
    let mut next_nodes = nodes;
    let mut appended: LruNode = node;
    appended.prev = tail;
    appended.next = 0;
    next_nodes[id] = appended;

    let next_head: int = if tail != 0 => {
        let mut tail_node: LruNode =(&next_nodes)[tail];
        tail_node.next = id;
        next_nodes[tail] = tail_node;
        head
    } else => {
        id
    };

    let out: LinkState = {nodes: next_nodes, head: next_head, tail: id};
    out
}

fn append_new_node(nodes, head, tail, id, key, value) {
    let mut next_nodes = nodes;
    let appended: LruNode = {key: key, value: value, prev: tail, next: 0};
    next_nodes[id] = appended;

    let next_head: int = if tail != 0 => {
        let mut tail_node: LruNode =(&next_nodes)[tail];
        tail_node.next = id;
        next_nodes[tail] = tail_node;
        head
    } else => {
        id
    };

    let out: LinkState = {nodes: next_nodes, head: next_head, tail: id};
    out
}

fn unlink_node(nodes, head, tail, id, node) {
    let prev =(&node).prev;
    let next =(&node).next;
    let mut next_nodes = nodes;
    let mut next_head = head;
    let mut next_tail = tail;

    if prev != 0 {
        let mut prev_node: LruNode =(&next_nodes)[prev];
        prev_node.next = next;
        next_nodes[prev] = prev_node;
    } else {
        next_head = next;
    }

    if next != 0 {
        let mut next_node: LruNode =(&next_nodes)[next];
        next_node.prev = prev;
        next_nodes[next] = next_node;
    } else {
        next_tail = prev;
    }

    let mut detached: LruNode = node;
    detached.prev = 0;
    detached.next = 0;
    next_nodes[id] = detached;

    let out: LinkState = {nodes: next_nodes, head: next_head, tail: next_tail};
    out
}

fn evict_oldest(limit, size, next_id, lookup, nodes, head, tail) {
    let out = if size == 0 || head == 0 => {
        make_cache(limit, size, next_id, head, tail, lookup, nodes)
    } else => {
        let head_node: LruNode = &((&nodes)[head]);
        let next_head = head_node.next;
        let mut next_lookup = lookup;
        let mut next_nodes = nodes;
        next_lookup[head_node.key.copy()] = null;
        next_nodes[head] = null;

        let next_tail = if tail == head => {
            0
        } else => {
            tail
        };

        if next_head != 0 {
            let mut next_node: LruNode =(&next_nodes)[next_head];
            next_node.prev = 0;
            next_nodes[next_head] = next_node;
        }

        make_cache(
            limit,
            size - 1,
            next_id,
            next_head,
            next_tail,
            next_lookup,
            next_nodes
        )
    };
    out
}

fn entry_report(cache, id) {
    let out: FeedCacheEntry = if id != 0 => {
        let node: LruNode = &((&cache).nodes[id]);
        {found: true, key: node.key.copy(), value: node.value.copy()}
    } else => {
        {found: false, key: "", value: empty_feed_item()}
    };
    out
}

pub fn new(raw_capacity) {
    let limit = normalized_capacity(raw_capacity);
    make_cache(limit, 0, 1, 0, 0, {}, {})
}

pub fn capacity(cache) {
    let state: LruCacheState = cache;
    normalized_capacity(state.capacity)
}

pub fn len(cache) {
    let state: LruCacheState = cache;
    state.size
}

pub fn is_empty(cache) {
    len(cache) == 0
}

pub fn has(cache, key) {
    let state: LruCacheState = cache;
    let lookup = state.lookup;
    lookup.has(key)
}

pub fn peek(cache, key) {
    let state: LruCacheState = cache;
    let lookup = state.lookup;
    let out: FeedCachePeek = if lookup.has(key) => {
        let id: int =(&lookup)[key];
        let node: LruNode = &((&state.nodes)[id]);
        {found: true, value: node.value.copy()}
    } else => {
        {found: false, value: empty_feed_item()}
    };
    out
}

pub fn get(cache, key) {
    let state: LruCacheState = cache;
    let limit = normalized_capacity(state.capacity);
    let size = state.size;
    let next_id = state.next_id;
    let head = state.head;
    let tail = state.tail;
    let lookup = state.lookup;
    let nodes = state.nodes;

    let out: FeedCacheHit = if lookup.has(key) => {
        let id: int =(&lookup)[key];
        let node: LruNode = &((&nodes)[id]);
        let next_cache = if id == tail => {
            make_cache(limit, size, next_id, head, tail, lookup, nodes)
        } else => {
            let node_copy: LruNode =(&nodes)[id];
            let unlinked: LinkState = unlink_node(nodes, head, tail, id, node_copy.copy());
            let relinked: LinkState = append_existing_node(
                unlinked.nodes,
                unlinked.head,
                unlinked.tail,
                id,
                node_copy
            );
            make_cache(
                limit,
                size,
                next_id,
                relinked.head,
                relinked.tail,
                lookup,
                relinked.nodes
            )
        };
        {cache: next_cache, found: true, value: node.value.copy()}
    } else => {
        {
            cache: make_cache(limit, size, next_id, head, tail, lookup, nodes),
            found: false,
            value: empty_feed_item()
        }
    };
    out
}

pub fn put(cache, key, value) {
    let state: LruCacheState = cache;
    let limit = normalized_capacity(state.capacity);
    let size = state.size;
    let next_id = state.next_id;
    let head = state.head;
    let tail = state.tail;
    let lookup = state.lookup;
    let nodes = state.nodes;

    let out = if limit == 0 => {
        make_cache(0, 0, 1, 0, 0, {}, {})
    } else => {
        if lookup.has(key) => {
            let id =(&lookup)[key];
            let mut node: LruNode =(&nodes)[id];
            node.value = value;
            if id == tail => {
                let mut next_nodes = nodes;
                next_nodes[id] = node;
                make_cache(limit, size, next_id, head, tail, lookup, next_nodes)
            } else => {
                let unlinked: LinkState = unlink_node(nodes, head, tail, id, node.copy());
                let relinked: LinkState = append_existing_node(
                    unlinked.nodes,
                    unlinked.head,
                    unlinked.tail,
                    id,
                    node
                );
                make_cache(
                    limit,
                    size,
                    next_id,
                    relinked.head,
                    relinked.tail,
                    lookup,
                    relinked.nodes
                )
            }
        } else => {
            let id = next_id;
            let mut next_lookup = lookup;
            let appended: LinkState = append_new_node(
                nodes,
                head,
                tail,
                id,
                key.copy(),
                value
            );
            let appended_head = appended.head;
            let appended_tail = appended.tail;
            let appended_nodes = appended.nodes;
            next_lookup[key] = id;
            if size + 1 > limit => {
                evict_oldest(
                    limit,
                    size + 1,
                    id + 1,
                    next_lookup,
                    appended_nodes,
                    appended_head,
                    appended_tail
                )
            } else => {
                make_cache(
                    limit,
                    size + 1,
                    id + 1,
                    appended_head,
                    appended_tail,
                    next_lookup,
                    appended_nodes
                )
            }
        }
    };
    out
}

pub fn touch(cache, key) {
    let state: LruCacheState = cache;
    let limit = normalized_capacity(state.capacity);
    let size = state.size;
    let next_id = state.next_id;
    let head = state.head;
    let tail = state.tail;
    let lookup = state.lookup;
    let nodes = state.nodes;

    let out = if lookup.has(key) => {
        let id: int =(&lookup)[key];
        if id != tail => {
            let node: LruNode =(&nodes)[id];
            let unlinked: LinkState = unlink_node(nodes, head, tail, id, node.copy());
            let relinked: LinkState = append_existing_node(
                unlinked.nodes,
                unlinked.head,
                unlinked.tail,
                id,
                node
            );
            make_cache(
                limit,
                size,
                next_id,
                relinked.head,
                relinked.tail,
                lookup,
                relinked.nodes
            )
        } else => {
            make_cache(limit, size, next_id, head, tail, lookup, nodes)
        }
    } else => {
        make_cache(limit, size, next_id, head, tail, lookup, nodes)
    };
    out
}

pub fn remove(cache, key) {
    let state: LruCacheState = cache;
    let limit = normalized_capacity(state.capacity);
    let size = state.size;
    let next_id = state.next_id;
    let head = state.head;
    let tail = state.tail;
    let lookup = state.lookup;
    let nodes = state.nodes;

    let out = if lookup.has(key) => {
        let id: int =(&lookup)[key];
        let node: LruNode =(&nodes)[id];
        let mut next_lookup = lookup;
        next_lookup[key] = null;
        let unlinked: LinkState = unlink_node(nodes, head, tail, id, node);
        let mut next_nodes = unlinked.nodes;
        next_nodes[id] = null;
        make_cache(
            limit,
            size - 1,
            next_id,
            unlinked.head,
            unlinked.tail,
            next_lookup,
            next_nodes
        )
    } else => {
        make_cache(limit, size, next_id, head, tail, lookup, nodes)
    };
    out
}

pub fn clear(cache) {
    let state: LruCacheState = cache;
    make_cache(normalized_capacity(state.capacity), 0, 1, 0, 0, {}, {})
}

pub fn keys(cache) {
    let state: LruCacheState = cache;
    let nodes = state.nodes;
    let mut current = state.head;
    let mut out: [string] = [];
    while current != 0 {
        let node: LruNode = &((&nodes)[current]);
        let next_id = node.next;
        out[out.length] = node.key.copy();
        current = next_id;
    }
    out
}

pub fn values(cache) {
    let state: LruCacheState = cache;
    let nodes = state.nodes;
    let mut current = state.head;
    let mut out: [FeedCacheItem] = [];
    while current != 0 {
        let node: LruNode = &((&nodes)[current]);
        let next_id = node.next;
        out[out.length] = node.value.copy();
        current = next_id;
    }
    out
}

pub fn entries(cache) {
    let state: LruCacheState = cache;
    let nodes = state.nodes;
    let mut current = state.head;
    let mut out: [FeedCacheRow] = [];
    while current != 0 {
        let node: LruNode = &((&nodes)[current]);
        let next_id = node.next;
        out[out.length] = {key: node.key.copy(), value: node.value.copy()};
        current = next_id;
    }
    out
}

pub fn oldest(cache) {
    let state: LruCacheState = cache;
    entry_report(state, state.head)
}

pub fn newest(cache) {
    let state: LruCacheState = cache;
    entry_report(state, state.tail)
}

let mut cache: LruCacheState = new(3);
assert(capacity(cache) == 3);
assert(is_empty(cache));

cache = put(
    cache,
    "world-news",
    {day: "2026-03-10", topic: "world news", article_count: 5, slug: "world-news"}
);
cache = put(
    cache,
    "markets",
    {day: "2026-03-10", topic: "markets", article_count: 7, slug: "markets"}
);
cache = put(
    cache,
    "build-ops",
    {day: "2026-03-10", topic: "build ops", article_count: 2, slug: "build-ops"}
);

assert(len(cache) == 3);
let initial_order: [string] = keys(cache);
assert(initial_order[0] == "world-news");
assert(initial_order[1] == "markets");
assert(initial_order[2] == "build-ops");

let mut world_hit: FeedCacheHit = get(cache, "world-news");
assert(world_hit.found);
let world_item: FeedCacheItem = world_hit.value.copy();
assert(world_item.article_count == 5);
assert(re::match("^[a-z-]+$", world_item.slug));
cache = world_hit.cache;

cache = put(
    cache,
    "breaking-alerts",
    {
        day: "2026-03-10",
        topic: "breaking alerts",
        article_count: 11,
        slug: "breaking-alerts"
    }
);

assert(has(cache, "markets") == false);
assert(peek(cache, "world-news").value.article_count == 5);

cache = touch(cache, "build-ops");

let oldest_entry: FeedCacheEntry = oldest(cache);
let newest_entry: FeedCacheEntry = newest(cache);
let oldest_key: string = oldest_entry.key.copy();
let newest_key: string = newest_entry.key.copy();
assert(oldest_key == "world-news");
assert(newest_key == "build-ops");

let visible_items: [FeedCacheItem] = values(cache);
let mut visible_topics: [string] = [];
let mut total_visible_articles: int = 0;
let visible_count = visible_items.length;
for (let mut index = 0; index < visible_count; index = index + 1) {
    let item: FeedCacheItem =(&visible_items)[index];
    visible_topics[visible_topics.length] = item.topic;
    total_visible_articles = total_visible_articles + item.article_count;
}
let cache_entries: [FeedCacheRow] = entries(cache);
assert(cache_entries[2].key == "build-ops");

let report = {
    order: keys(cache),
    oldest_key: oldest_key,
    newest_key: newest_key,
    visible_topics: visible_topics,
    total_visible_articles: total_visible_articles
};

let archived: LruCacheState = remove(cache, "world-news");
assert(has(archived, "world-news") == false);

let cleared: LruCacheState = clear(cache);
assert(capacity(cleared) == 3);
assert(is_empty(cleared));

print(json::encode(report));
