use super::rss::set::{add, difference, equals, from, has, intersect, is_subset, remove, union};

let mut unique = from([1, 2, 2, 3, 1]);
let mut unique_view = unique.copy();
assert(unique_view.length == 3);
assert(unique_view[0] == 1);
assert(unique_view[1] == 2);
assert(unique_view[2] == 3);
assert(has(unique.copy(), 2));
assert(has(unique.copy(), 9) == false);

let mut expanded = add(unique, 4);
let mut expanded_view = expanded.copy();
assert(expanded_view.length == 4);
assert(expanded_view[3] == 4);

let mut unchanged = add(expanded.copy(), 4);
assert(unchanged.length == 4);

let mut removed = remove([1, 2, 2, 3, 4], 2);
assert(removed.length == 3);
assert(removed[0] == 1);
assert(removed[1] == 3);
assert(removed[2] == 4);

let mut joined = union([1, 2, 2],[2, 3, 4, 3]);
let mut joined_view = joined.copy();
assert(joined_view.length == 4);
assert(joined_view[0] == 1);
assert(joined_view[1] == 2);
assert(joined_view[2] == 3);
assert(joined_view[3] == 4);

let mut shared = intersect([1, 2, 3, 2],[2, 4, 3, 3]);
let mut shared_view = shared.copy();
assert(shared_view.length == 2);
assert(shared_view[0] == 2);
assert(shared_view[1] == 3);

let mut left_only = difference([1, 2, 3, 2],[2, 4]);
let mut left_only_view = left_only.copy();
assert(left_only_view.length == 2);
assert(left_only_view[0] == 1);
assert(left_only_view[1] == 3);

assert(is_subset([1, 2],[2, 1, 3]));
assert(is_subset([1, 4],[1, 2, 3]) == false);
assert(equals([1, 2, 2, 3],[3, 2, 1]));
assert(equals([1, 2],[1, 2, 3]) == false);
