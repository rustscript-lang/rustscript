use super::rss::strings as string;
use io;

assert(io::exists("stdlib/rss/strings.rss"));

let mut handle = io::popen("echo rustscript_io_builtin", "r");
let mut output = io::read_all(handle);
let mut closed = io::close(handle);
assert(closed);
assert(string::contains(output, "rustscript_io_builtin"));
