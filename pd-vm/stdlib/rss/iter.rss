// Iteration helpers implemented in pure RustScript.

pub fn range_step(start, stop, step) {
    let mut out = [];
    if step != 0 {
        let mut value = start;
        if step > 0 {
            while value < stop {
                out[(out).length] = value;
                value = value + step;
            }
        } else {
            while value > stop {
                out[(out).length] = value;
                value = value + step;
            }
        }
    }
    out;
}

pub fn range(stop) {
    range_step(0, stop, 1);
}

pub fn enumerate(values) {
    let mut out = [];
    let mut index = 0;
    while index < (values).length {
        out[(out).length] = [index, values[index]];
        index = index + 1;
    }
    out;
}

pub fn take(values, count) {
    let mut out = [];
    if count > 0 {
        out = values[0:count];
    }
    out;
}

pub fn skip(values, count) {
    let mut start = 0;
    if count > 0 {
        start = count;
    }
    if start > (values).length {
        start = (values).length;
    }
    values[start:(values).length];
}

pub fn chunk(values, size) {
    let mut out = [];
    if size > 0 {
        let mut index = 0;
        let mut value_len = (values).length;
        while index < value_len {
            let mut next = index + size;
            if next > value_len {
                next = value_len;
            }
            out[(out).length] = values[index:next];
            index = next;
        }
    }
    out;
}

pub fn sum(values) {
    let mut out = 0;
    let mut index = 0;
    while index < (values).length {
        out = out + values[index];
        index = index + 1;
    }
    out;
}

pub fn any_true(values) {
    let mut out = false;
    let mut index = 0;
    while index < (values).length {
        if values[index] {
            out = true;
            break;
        }
        index = index + 1;
    }
    out;
}

pub fn all_true(values) {
    let mut out = true;
    let mut index = 0;
    while index < (values).length {
        if values[index] == false {
            out = false;
            break;
        }
        index = index + 1;
    }
    out;
}

pub fn map(values, func) {
    let mut out = [];
    let mut index = 0;
    while index < (values).length {
        out[(out).length] = func(values[index]);
        index = index + 1;
    }
    out;
}

pub fn filter(values, pred) {
    let mut out = [];
    let mut index = 0;
    while index < (values).length {
        let mut value = values[index];
        if pred(value) {
            out[(out).length] = value;
        }
        index = index + 1;
    }
    out;
}

pub fn reduce(values, init, func) {
    let mut acc = init;
    let mut index = 0;
    while index < (values).length {
        acc = func(acc, values[index]);
        index = index + 1;
    }
    acc;
}

pub fn each(values, func) {
    let mut index = 0;
    while index < (values).length {
        let mut each_result = func(values[index]);
        index = index + 1;
    }
    null;
}
