// Path helpers implemented in pure RustScript.

fn is_separator(ch) {
    ch == "/" || ch == "\\";
}

fn trim_trailing_separators(path) {
    let mut end = (path).length;
    while end > 1 && is_separator((path)[(end - 1):end]) {
        end = end - 1;
    }
    (path)[0:end];
}

pub fn normalize_sep(path) {
    let mut out = "";
    for (let mut index = 0; index < (path).length; index = index + 1) {
        let ch = (path)[index:(index + 1)];
        let segment = if ch == "\\" => { "/" } else => { ch };
        out = out + segment;
    }
    out;
}

pub fn join(lhs, rhs) {
    let left = normalize_sep(lhs);
    let right = normalize_sep(rhs);
    let out = if (left).length == 0 => {
        right
    } else if (right).length == 0 => {
        left
    } else => {
        let left_last = (left)[((left).length - 1):(left).length];
        let right_first = (right)[0:1];
        if is_separator(left_last) && is_separator(right_first) => {
            left + (right)[1:(right).length]
        } else if is_separator(left_last) || is_separator(right_first) => {
            left + right
        } else => {
            left + "/" + right
        }
    };
    out;
}

pub fn basename(path) {
    let mut normalized = trim_trailing_separators(normalize_sep(path));
    let mut start = 0;
    let mut index = (normalized).length - 1;
    while index > -1 {
        if (normalized)[index:(index + 1)] == "/" {
            start = index + 1;
            break;
        }
        index = index - 1;
    }
    (normalized)[start:(normalized).length];
}

pub fn dirname(path) {
    let mut normalized = trim_trailing_separators(normalize_sep(path));
    let mut cut = -1;
    let mut index = (normalized).length - 1;
    while index > -1 {
        if (normalized)[index:(index + 1)] == "/" {
            cut = index;
            break;
        }
        index = index - 1;
    }
    let out = if cut < 0 => {
        ""
    } else if cut == 0 => {
        "/"
    } else => {
        (normalized)[0:cut]
    };
    out;
}

pub fn extname(path) {
    let mut name = basename(path);
    let mut dot = -1;
    let mut index = (name).length - 1;
    while index > -1 {
        if (name)[index:(index + 1)] == "." {
            dot = index;
            break;
        }
        index = index - 1;
    }
    let out = if dot < 1 => {
        ""
    } else => {
        (name)[dot:(name).length]
    };
    out;
}
