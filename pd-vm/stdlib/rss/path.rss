// Path helpers implemented in pure RustScript.

fn is_separator(ch) {
    ch == "/" || ch == "\\";
}

fn trim_trailing_separators(path) {
    let mut out = path;
    let mut path_len = (path).length;
    let mut end = path_len;
    while end > 1 && is_separator((path)[(end - 1):end]) {
        end = end - 1;
    }
    out = (path)[0:end];
    out;
}

pub fn normalize_sep(path) {
    let mut out = "";
    let mut index = 0;
    while index < (path).length {
        let mut ch = (path)[index:(index + 1)];
        if ch == "\\" {
            out = out + "/";
        } else {
            out = out + ch;
        }
        index = index + 1;
    }
    out;
}

pub fn join(lhs, rhs) {
    let mut left = normalize_sep(lhs);
    let mut right = normalize_sep(rhs);
    let mut out = "";
    if (left).length == 0 {
        out = right;
    } else {
        if (right).length == 0 {
            out = left;
        } else {
            let mut left_last = (left)[((left).length - 1):(left).length];
            let mut right_first = (right)[0:1];
            if is_separator(left_last) && is_separator(right_first) {
                out = left + (right)[1:(right).length];
            } else {
                if is_separator(left_last) || is_separator(right_first) {
                    out = left + right;
                } else {
                    out = left + "/" + right;
                }
            }
        }
    }
    out;
}

pub fn basename(path) {
    let mut normalized = trim_trailing_separators(normalize_sep(path));
    let mut start = 0;
    let mut index = (normalized).length - 1;
    while index > -1 {
        if (normalized)[index:(index + 1)] == "/" {
            start = index + 1;
            break;
        }
        index = index - 1;
    }
    (normalized)[start:(normalized).length];
}

pub fn dirname(path) {
    let mut normalized = trim_trailing_separators(normalize_sep(path));
    let mut cut = -1;
    let mut out = "";
    let mut index = (normalized).length - 1;
    while index > -1 {
        if (normalized)[index:(index + 1)] == "/" {
            cut = index;
            break;
        }
        index = index - 1;
    }

    if cut < 0 {
        out = "";
    } else {
        if cut == 0 {
            out = "/";
        } else {
            out = (normalized)[0:cut];
        }
    }
    out;
}

pub fn extname(path) {
    let mut name = basename(path);
    let mut dot = -1;
    let mut out = "";
    let mut index = (name).length - 1;
    while index > -1 {
        if (name)[index:(index + 1)] == "." {
            dot = index;
            break;
        }
        index = index - 1;
    }
    if dot < 1 {
        out = "";
    } else {
        out = (name)[dot:(name).length];
    }
    out;
}
