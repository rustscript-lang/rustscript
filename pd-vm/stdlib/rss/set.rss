// Set helpers implemented in pure RustScript using arrays with stable insertion order.
fn index_of(values, needle) {
    let mut out =-1;
    for (let mut index = 0; index < values.length; index = index + 1) {
        if values[index] == needle {
            out = index;
            break;
        }
    }
    out;
}

// Returns whether a set array contains a value.
pub fn has(values, needle) {
    index_of(values, needle) >-1;
}

// Returns a de-duplicated set array preserving insertion order.
pub fn from(values) {
    let mut out = [];
    for (let mut index = 0; index < values.length; index = index + 1) {
        let value = values[index];
        if has(out, value) == false {
            out[out.length] = value;
        }
    }
    out;
}

// Returns a set array with a value inserted.
pub fn add(values, needle) {
    let mut out = from(values);
    if has(out, needle) == false {
        out[out.length] = needle;
    }
    out;
}

// Returns a set array with a value removed.
pub fn remove(values, needle) {
    let mut out = [];
    for (let mut index = 0; index < values.length; index = index + 1) {
        let value = values[index];
        if value != needle && has(out, value) == false {
            out[out.length] = value;
        }
    }
    out;
}

// Returns the union of two set arrays.
pub fn union(lhs, rhs) {
    let mut out = from(lhs);
    for (let mut index = 0; index < rhs.length; index = index + 1) {
        let value = rhs[index];
        if has(out, value) == false {
            out[out.length] = value;
        }
    }
    out;
}

// Returns the intersection of two set arrays.
pub fn intersect(lhs, rhs) {
    let left = from(lhs);
    let right = from(rhs);
    let mut out = [];
    for (let mut index = 0; index <(&left).length; index = index + 1) {
        let value =(&left)[index];
        if has(right, value) {
            out[out.length] = value;
        }
    }
    out;
}

// Returns the values in lhs that are not in rhs.
pub fn difference(lhs, rhs) {
    let left = from(lhs);
    let right = from(rhs);
    let mut out = [];
    for (let mut index = 0; index <(&left).length; index = index + 1) {
        let value =(&left)[index];
        if has(right, value) == false {
            out[out.length] = value;
        }
    }
    out;
}

// Returns whether lhs is a subset of rhs.
pub fn is_subset(lhs, rhs) {
    let left = from(lhs);
    let right = from(rhs);
    let mut out = true;
    for (let mut index = 0; index <(&left).length; index = index + 1) {
        if has(right,(&left)[index]) == false {
            out = false;
            break;
        }
    }
    out;
}

// Returns whether two set arrays contain the same values.
pub fn equals(lhs, rhs) {
    is_subset(lhs, rhs) && is_subset(rhs, lhs);
}
