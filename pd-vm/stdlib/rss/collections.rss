// Collection helpers implemented in pure RustScript.

fn map_has_key(map, key) {
    let mut keys = (map).keys;
    let mut key_index = 0;
    let mut found = false;
    while key_index < (keys).length {
        if keys[key_index] == key {
            found = true;
            break;
        }
        key_index = key_index + 1;
    }
    found;
}

pub fn append(lhs, rhs) {
    lhs + rhs;
}

pub fn index_of(values, needle) {
    let mut find_index = 0;
    let mut found = -1;
    while find_index < (values).length {
        if values[find_index] == needle {
            found = find_index;
            break;
        }
        find_index = find_index + 1;
    }
    found;
}

pub fn contains(values, needle) {
    index_of(values, needle) > -1;
}

pub fn reverse(values) {
    let mut out = [];
    let mut reverse_index = (values).length - 1;
    while reverse_index > -1 {
        out[(out).length] = values[reverse_index];
        reverse_index = reverse_index - 1;
    }
    out;
}

pub fn dedup(values) {
    let mut out = [];
    let mut dedup_index = 0;
    while dedup_index < (values).length {
        let mut value = values[dedup_index];
        if contains(out, value) == false {
            out[(out).length] = value;
        }
        dedup_index = dedup_index + 1;
    }
    out;
}

pub fn has(map, key) {
    let mut keys = (map).keys;
    let mut key_index = 0;
    let mut found = false;
    while key_index < (keys).length {
        if keys[key_index] == key {
            found = true;
            break;
        }
        key_index = key_index + 1;
    }
    found;
}

pub fn get_or(map, key, fallback) {
    let mut out = fallback;
    if has(map, key) {
        out = map[key];
    }
    out;
}

pub fn values(map) {
    let mut keys = (map).keys;
    let mut out = [];
    let mut value_index = 0;
    while value_index < (keys).length {
        let mut key = keys[value_index];
        out[(out).length] = map[key];
        value_index = value_index + 1;
    }
    out;
}

pub fn entries(map) {
    let mut keys = (map).keys;
    let mut out = [];
    let mut entry_index = 0;
    while entry_index < (keys).length {
        let mut key = keys[entry_index];
        out[(out).length] = [key, map[key]];
        entry_index = entry_index + 1;
    }
    out;
}

pub fn merge(lhs, rhs) {
    let mut out = {};

    let mut lhs_keys = (lhs).keys;
    let mut left_index = 0;
    while left_index < (lhs_keys).length {
        let mut key = lhs_keys[left_index];
        out[key] = lhs[key];
        left_index = left_index + 1;
    }

    let mut rhs_keys = (rhs).keys;
    let mut right_index = 0;
    while right_index < (rhs_keys).length {
        let mut key = rhs_keys[right_index];
        out[key] = rhs[key];
        right_index = right_index + 1;
    }
    out;
}

pub fn deep_compare(lhs, rhs) {
    let mut pending = [[lhs, rhs]];
    let mut out = true;

    while (pending).length > 0 {
        let mut next_index = (pending).length - 1;
        let mut next = pending[next_index].copy();
        pending = pending[0:next_index];

        let mut left = next[0];
        let mut right = next[1];
        let mut lhs_type = type(left);
        let mut rhs_type = type(right);

        if lhs_type != rhs_type {
            out = false;
            break;
        }

        if lhs_type == "array" {
            if (left).length != (right).length {
                out = false;
                break;
            }
            let mut index = (left).length - 1;
            while index > -1 {
                pending[(pending).length] = [left[index], right[index]];
                index = index - 1;
            }
        } else if lhs_type == "map" {
            let mut lhs_keys = (left).keys;
            let mut rhs_keys = (right).keys;
            if (lhs_keys).length != (rhs_keys).length {
                out = false;
                break;
            }
            let mut index = (lhs_keys).length - 1;
            while index > -1 {
                let mut key = lhs_keys[index];
                if map_has_key(right, key) == false {
                    out = false;
                    break;
                }
                pending[(pending).length] = [left[key], right[key]];
                index = index - 1;
            }
            if out == false {
                break;
            }
        } else if left != right {
            out = false;
            break;
        }
    }
    out;
}
