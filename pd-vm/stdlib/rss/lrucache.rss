// LRU cache helpers implemented in pure RustScript.
//
// The live set uses:
// - `lookup`: user key -> node id
// - `nodes`: node id -> LruNode
//
// Node ids start at 1. The cache uses `0` as the internal "no link" sentinel,
// because storing `null` into a map entry now deletes that entry.
struct LruNode {
    key: unknown,
    value: unknown,
    prev: int,
    next: int
}

struct LinkState {
    nodes: map,
    head: int,
    tail: int
}

struct LruCacheState {
    capacity: int,
    size: int,
    next_id: int,
    head: int,
    tail: int,
    lookup: map,
    nodes: map
}

fn normalized_capacity(raw_capacity) {
    let out = if raw_capacity > 0 => {
        raw_capacity
    } else => {
        0
    };
    out
}

fn make_cache(limit, size, next_id, head, tail, lookup, nodes) {
    let out: LruCacheState = {
        capacity: limit,
        size: size,
        next_id: next_id,
        head: head,
        tail: tail,
        lookup: lookup,
        nodes: nodes
    };
    out
}

fn append_existing_node(nodes, head, tail, id, node) {
    let mut next_nodes = nodes;
    let mut appended: LruNode = node;
    appended.prev = tail;
    appended.next = 0;
    next_nodes[id] = appended;

    let next_head = if tail != 0 => {
        let mut tail_node: LruNode = next_nodes[tail].copy();
        tail_node.next = id;
        next_nodes[tail] = tail_node;
        head
    } else => {
        id
    };

    let out: LinkState = {nodes: next_nodes, head: next_head, tail: id};
    out
}

fn append_new_node(nodes, head, tail, id, key, value) {
    let mut next_nodes = nodes;
    let appended: LruNode = {key: key, value: value, prev: tail, next: 0};
    next_nodes[id] = appended;

    let next_head = if tail != 0 => {
        let mut tail_node: LruNode = next_nodes[tail].copy();
        tail_node.next = id;
        next_nodes[tail] = tail_node;
        head
    } else => {
        id
    };

    let out: LinkState = {nodes: next_nodes, head: next_head, tail: id};
    out
}

fn unlink_node(nodes, head, tail, id, node) {
    let node_view: LruNode = node.copy();
    let prev = node_view.prev;
    let next = node_view.next;
    let mut next_nodes = nodes;
    let mut next_head = head;
    let mut next_tail = tail;

    if prev != 0 {
        let mut prev_node: LruNode = next_nodes[prev].copy();
        prev_node.next = next;
        next_nodes[prev] = prev_node;
    } else {
        next_head = next;
    }

    if next != 0 {
        let mut next_node: LruNode = next_nodes[next].copy();
        next_node.prev = prev;
        next_nodes[next] = next_node;
    } else {
        next_tail = prev;
    }

    let mut detached: LruNode = node;
    detached.prev = 0;
    detached.next = 0;
    next_nodes[id] = detached;

    let out: LinkState = {nodes: next_nodes, head: next_head, tail: next_tail};
    out
}

fn evict_oldest(limit, size, next_id, lookup, nodes, head, tail) {
    let out = if size == 0 || head == 0 => {
        make_cache(limit, size, next_id, head, tail, lookup, nodes)
    } else => {
        let head_node: LruNode =&((&nodes)[head]);
        let next_head = head_node.next;
        let evicted_key = head_node.key.copy();
        let mut next_lookup = lookup;
        let mut next_nodes = nodes;
        next_lookup[evicted_key] = null;
        next_nodes[head] = null;

        let next_tail = if tail == head => {
            0
        } else => {
            tail
        };

        if next_head != 0 {
            let mut next_node: LruNode =(&next_nodes)[next_head];
            next_node.prev = 0;
            next_nodes[next_head] = next_node;
        }

        make_cache(
            limit,
            size - 1,
            next_id,
            next_head,
            next_tail,
            next_lookup,
            next_nodes
        )
    };
    out
}

fn entry_report(cache, id) {
    let out = if id != 0 => {
        let node: LruNode =&((&cache).nodes[id]);
        {found: true, key: node.key, value: node.value}
    } else => {
        {found: false, key: null, value: null}
    };
    out
}

pub fn new(raw_capacity) {
    let limit = normalized_capacity(raw_capacity);
    make_cache(limit, 0, 1, 0, 0, {}, {})
}

pub fn capacity(cache) {
    let state: LruCacheState = cache;
    normalized_capacity(state.capacity)
}

pub fn len(cache) {
    let state: LruCacheState = cache;
    state.size
}

pub fn is_empty(cache) {
    len(cache) == 0
}

pub fn has(cache, key) {
    let state: LruCacheState = cache;
    let lookup = state.lookup;
    lookup.has(key)
}

pub fn peek(cache, key) {
    let state: LruCacheState = cache;
    let lookup = state.lookup;
    let out = if lookup.has(key) => {
        let id =(&lookup)[key];
        let node: LruNode =&((&state.nodes)[id]);
        {found: true, value: node.value}
    } else => {
        {found: false, value: null}
    };
    out
}

pub fn get(cache, key) {
    let state: LruCacheState = cache;
    let limit = normalized_capacity(state.capacity);
    let size = state.size;
    let next_id = state.next_id;
    let head = state.head;
    let tail = state.tail;
    let lookup = state.lookup;
    let nodes = state.nodes;

    let out = if lookup.has(key) => {
        let id =(&lookup)[key];
        let node: LruNode =&((&nodes)[id]);
        let value = node.value;
        let next_cache = if id == tail => {
            make_cache(limit, size, next_id, head, tail, lookup, nodes)
        } else => {
            let node_copy: LruNode =(&nodes)[id];
            let unlinked: LinkState = unlink_node(nodes, head, tail, id, node_copy.copy());
            let relinked: LinkState = append_existing_node(
                unlinked.nodes,
                unlinked.head,
                unlinked.tail,
                id,
                node_copy
            );
            make_cache(
                limit,
                size,
                next_id,
                relinked.head,
                relinked.tail,
                lookup,
                relinked.nodes
            )
        };
        {cache: next_cache, found: true, value: value}
    } else => {
        {
            cache: make_cache(limit, size, next_id, head, tail, lookup, nodes),
            found: false,
            value: null
        }
    };
    out
}

pub fn put(cache, key, value) {
    let state: LruCacheState = cache;
    let limit = normalized_capacity(state.capacity);
    let size = state.size;
    let next_id = state.next_id;
    let head = state.head;
    let tail = state.tail;
    let lookup = state.lookup;
    let nodes = state.nodes;

    let out = if limit == 0 => {
        make_cache(0, 0, 1, 0, 0, {}, {})
    } else => {
        if lookup.has(key) => {
            let id =(&lookup)[key];
            let mut node: LruNode =(&nodes)[id];
            node.value = value;
            if id == tail => {
                let mut next_nodes = nodes;
                next_nodes[id] = node;
                make_cache(limit, size, next_id, head, tail, lookup, next_nodes)
            } else => {
                let unlinked: LinkState = unlink_node(nodes, head, tail, id, node.copy());
                let relinked: LinkState = append_existing_node(
                    unlinked.nodes,
                    unlinked.head,
                    unlinked.tail,
                    id,
                    node
                );
                make_cache(
                    limit,
                    size,
                    next_id,
                    relinked.head,
                    relinked.tail,
                    lookup,
                    relinked.nodes
                )
            }
        } else => {
            let id = next_id;
            let mut next_lookup = lookup;
            let appended: LinkState = append_new_node(nodes, head, tail, id, key.copy(), value);
            let appended_head = appended.head;
            let appended_tail = appended.tail;
            let appended_nodes = appended.nodes;
            next_lookup[key] = id;
            if size + 1 > limit => {
                evict_oldest(
                    limit,
                    size + 1,
                    id + 1,
                    next_lookup,
                    appended_nodes,
                    appended_head,
                    appended_tail
                )
            } else => {
                make_cache(
                    limit,
                    size + 1,
                    id + 1,
                    appended_head,
                    appended_tail,
                    next_lookup,
                    appended_nodes
                )
            }
        }
    };
    out
}

pub fn touch(cache, key) {
    let state: LruCacheState = cache;
    let limit = normalized_capacity(state.capacity);
    let size = state.size;
    let next_id = state.next_id;
    let head = state.head;
    let tail = state.tail;
    let lookup = state.lookup;
    let nodes = state.nodes;

    let out = if lookup.has(key) => {
        let id =(&lookup)[key];
        if id != tail => {
            let node: LruNode =(&nodes)[id];
            let unlinked: LinkState = unlink_node(nodes, head, tail, id, node.copy());
            let relinked: LinkState = append_existing_node(
                unlinked.nodes,
                unlinked.head,
                unlinked.tail,
                id,
                node
            );
            make_cache(
                limit,
                size,
                next_id,
                relinked.head,
                relinked.tail,
                lookup,
                relinked.nodes
            )
        } else => {
            make_cache(limit, size, next_id, head, tail, lookup, nodes)
        }
    } else => {
        make_cache(limit, size, next_id, head, tail, lookup, nodes)
    };
    out
}

pub fn remove(cache, key) {
    let state: LruCacheState = cache;
    let limit = normalized_capacity(state.capacity);
    let size = state.size;
    let next_id = state.next_id;
    let head = state.head;
    let tail = state.tail;
    let lookup = state.lookup;
    let nodes = state.nodes;

    let out = if lookup.has(key) => {
        let id =(&lookup)[key];
        let node: LruNode =(&nodes)[id];
        let mut next_lookup = lookup;
        next_lookup[key] = null;
        let unlinked: LinkState = unlink_node(nodes, head, tail, id, node);
        let mut next_nodes = unlinked.nodes;
        next_nodes[id] = null;
        make_cache(
            limit,
            size - 1,
            next_id,
            unlinked.head,
            unlinked.tail,
            next_lookup,
            next_nodes
        )
    } else => {
        make_cache(limit, size, next_id, head, tail, lookup, nodes)
    };
    out
}

pub fn clear(cache) {
    let state: LruCacheState = cache;
    make_cache(normalized_capacity(state.capacity), 0, 1, 0, 0, {}, {})
}

pub fn keys(cache) {
    let state: LruCacheState = cache;
    let nodes = state.nodes;
    let mut current = state.head;
    let mut out =[];
    while current != 0 {
        let node: LruNode =&((&nodes)[current]);
        let next_id = node.next;
        out[out.length] = node.key;
        current = next_id;
    }
    out
}

pub fn values(cache) {
    let state: LruCacheState = cache;
    let nodes = state.nodes;
    let mut current = state.head;
    let mut out =[];
    while current != 0 {
        let node: LruNode =&((&nodes)[current]);
        let next_id = node.next;
        out[out.length] = node.value;
        current = next_id;
    }
    out
}

pub fn entries(cache) {
    let state: LruCacheState = cache;
    let nodes = state.nodes;
    let mut current = state.head;
    let mut out =[];
    while current != 0 {
        let node: LruNode =&((&nodes)[current]);
        let next_id = node.next;
        out[out.length] =[node.key, node.value];
        current = next_id;
    }
    out
}

pub fn oldest(cache) {
    let state: LruCacheState = cache;
    entry_report(state, state.head)
}

pub fn newest(cache) {
    let state: LruCacheState = cache;
    entry_report(state, state.tail)
}
