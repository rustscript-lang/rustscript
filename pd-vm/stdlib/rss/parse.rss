// Parsing helpers implemented in pure RustScript.

fn is_whitespace(ch) {
    let mut out = false;
    if ch == " " {
        out = true;
    }
    if ch == "\n" {
        out = true;
    }
    if ch == "\r" {
        out = true;
    }
    if ch == "\t" {
        out = true;
    }
    out;
}

fn trim(value) {
    let mut value_len = (value).length;
    let mut start = 0;
    while start < value_len {
        if is_whitespace((value)[start:(start + 1)]) {
            start = start + 1;
        } else {
            break;
        }
    }

    let mut end = value_len;
    while end > start {
        if is_whitespace((value)[(end - 1):end]) {
            end = end - 1;
        } else {
            break;
        }
    }
    (value)[start:end];
}

fn digit_value(ch) {
    let mut out = -1;
    if ch == "0" {
        out = 0;
    } else if ch == "1" {
        out = 1;
    } else if ch == "2" {
        out = 2;
    } else if ch == "3" {
        out = 3;
    } else if ch == "4" {
        out = 4;
    } else if ch == "5" {
        out = 5;
    } else if ch == "6" {
        out = 6;
    } else if ch == "7" {
        out = 7;
    } else if ch == "8" {
        out = 8;
    } else if ch == "9" {
        out = 9;
    } else if ch == "a" || ch == "A" {
        out = 10;
    } else if ch == "b" || ch == "B" {
        out = 11;
    } else if ch == "c" || ch == "C" {
        out = 12;
    } else if ch == "d" || ch == "D" {
        out = 13;
    } else if ch == "e" || ch == "E" {
        out = 14;
    } else if ch == "f" || ch == "F" {
        out = 15;
    } else if ch == "g" || ch == "G" {
        out = 16;
    } else if ch == "h" || ch == "H" {
        out = 17;
    } else if ch == "i" || ch == "I" {
        out = 18;
    } else if ch == "j" || ch == "J" {
        out = 19;
    } else if ch == "k" || ch == "K" {
        out = 20;
    } else if ch == "l" || ch == "L" {
        out = 21;
    } else if ch == "m" || ch == "M" {
        out = 22;
    } else if ch == "n" || ch == "N" {
        out = 23;
    } else if ch == "o" || ch == "O" {
        out = 24;
    } else if ch == "p" || ch == "P" {
        out = 25;
    } else if ch == "q" || ch == "Q" {
        out = 26;
    } else if ch == "r" || ch == "R" {
        out = 27;
    } else if ch == "s" || ch == "S" {
        out = 28;
    } else if ch == "t" || ch == "T" {
        out = 29;
    } else if ch == "u" || ch == "U" {
        out = 30;
    } else if ch == "v" || ch == "V" {
        out = 31;
    } else if ch == "w" || ch == "W" {
        out = 32;
    } else if ch == "x" || ch == "X" {
        out = 33;
    } else if ch == "y" || ch == "Y" {
        out = 34;
    } else if ch == "z" || ch == "Z" {
        out = 35;
    }
    out;
}

fn is_valid_base(base) {
    base >= 2 && base <= 36;
}

pub fn is_int_literal_base(value, base) {
    let mut text = trim(value);
    let mut text_len = (text).length;
    let mut out = true;
    let mut index = 0;
    if is_valid_base(base) == false || text_len == 0 {
        out = false;
    } else {
        let mut first = (text)[0:1];
        if first == "+" || first == "-" {
            index = 1;
        }
        if index == text_len {
            out = false;
        } else {
            while index < text_len {
                let mut digit = digit_value((text)[index:(index + 1)]);
                if digit < 0 || digit >= base {
                    out = false;
                    break;
                }
                index = index + 1;
            }
        }
    }
    out;
}

pub fn is_int_literal(value) {
    is_int_literal_base(value, 10);
}

pub fn try_parse_int_base(value, base) {
    let mut text = trim(value);
    let mut out = null;
    if is_int_literal_base(text, base) {
        let mut sign = 1;
        let mut index = 0;
        let mut parsed = 0;
        let mut first = (text)[0:1];
        if first == "-" {
            sign = -1;
            index = 1;
        } else if first == "+" {
            index = 1;
        }
        while index < (text).length {
            parsed = parsed * base + digit_value((text)[index:(index + 1)]);
            index = index + 1;
        }
        out = parsed * sign;
    }
    out;
}

pub fn try_parse_int(value) {
    try_parse_int_base(value, 10);
}

pub fn parse_int_base_or(value, base, fallback) {
    let mut out = try_parse_int_base(value, base);
    if type(out) == "null" {
        out = fallback;
    }
    out;
}

pub fn parse_int_or(value, fallback) {
    let mut out = try_parse_int(value);
    if type(out) == "null" {
        out = fallback;
    }
    out;
}

pub fn is_bool_literal(value) {
    let mut text = trim(value);
    text == "true" || text == "false";
}

pub fn try_parse_bool(value) {
    let mut text = trim(value);
    let mut out = null;
    if text == "true" {
        out = true;
    } else if text == "false" {
        out = false;
    }
    out;
}

pub fn parse_bool_or(value, fallback) {
    let mut out = try_parse_bool(value);
    if type(out) == "null" {
        out = fallback;
    }
    out;
}
