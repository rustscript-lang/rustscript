use vm::{add_one};

let mut i = 0;
let mut total = 0;
while i < 3 {
    total = total + 1;
    i = i + 1;
}

let base = add_one(0);
fn bump_with_base(v) { v + base; }

fn drive(seed) {
    fn inner(v) { v + seed; }
    inner(2);
}

if total != 3 {
    print(0);
} else {
    print(bump_with_base(drive(3)));
}
