use http;
use proxy;
use tcp;
use tls;

let upstream_scheme = http::request::get_header("x-upstream-scheme");
let upstream_host = if upstream_scheme == "https" => { "localhost" } else => { "127.0.0.1" };
let upstream_port = if upstream_scheme == "https" => { 18486 } else => { 18086 };
let upstream_path = "/echo";

// Bind the default outbound exchange to the requested target.
let exchange = http::exchange::default_upstream();
http::exchange::set_target(exchange, upstream_host, upstream_port);
if upstream_scheme != "" {
    http::exchange::set_scheme(exchange, upstream_scheme);
}
http::exchange::set_path(exchange, upstream_path);

// Export the downstream side as a byte-stream endpoint.
let downstream = proxy::stream::downstream();
let upstream_socket = tcp::stream::default_upstream();
let upstream_tls = tls::session::from_socket(upstream_socket);
if tls::session::is_present(upstream_tls) {
    tls::session::set_verify(upstream_tls, false);
}

let mut status = "";
if tls::session::is_present(upstream_tls) {
    // Bridge against decrypted TLS plaintext when the outbound side is HTTPS.
    let upstream = proxy::stream::from_tls_plaintext(upstream_tls);
    status = proxy::bridge(downstream, upstream, 4);
} else {
    // Plain HTTP can bridge directly against the default upstream exchange stream.
    let upstream = proxy::stream::exchange(exchange);
    status = proxy::bridge(downstream, upstream, 4);
}

http::response::set_header("x-proxy-status", status);

// After the tunnel completes, mirror response metadata that the exchange produced.
let upstream_status = http::exchange::get_status(exchange);
if upstream_status != 0 {
    http::response::set_status(upstream_status);
}

let content_type = http::exchange::get_header(exchange, "content-type");
if content_type != "" {
    http::response::set_header("content-type", content_type);
}

if tls::session::is_present(upstream_tls) {
    // TLS inspection data is only meaningful when the upstream path used TLS.
    let peer_name = tls::session::get_peer_name(upstream_tls);
    if peer_name != "" {
        http::response::set_header("x-peer-name", peer_name);
    }
    let alpn = tls::session::get_alpn(upstream_tls);
    if alpn != "" {
        http::response::set_header("x-upstream-alpn", alpn);
    }
}
