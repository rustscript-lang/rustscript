// Run with:
// cargo run -p pd-edge --bin pd-edge-console -- --program pd-edge/examples/console/sample_console_http3_client.rss --run -- 127.0.0.1 GET
// Pass "-" as the body argument to stream the request body from stdin.
// Pass "false" as the fourth argument to disable TLS certificate verification.

use console;
use http;
use runtime;
use tls;

let argc = console::args::count();

if argc == 0 {
    console::stderr::write("usage: <host> [method] [body|-] [verify=true|false]\n");
    console::stderr::write("example: 127.0.0.1 POST - false\n");
    console::stderr::flush();
    runtime::exit();
} else {
    let host = console::args::get(0);
    let port = 4443;
    if host == "" {
        console::stderr::write("host is required\n");
        console::stderr::flush();
        runtime::exit();
    }
    let method = if argc > 1 => {
        console::args::get(1)
    } else => {
        "GET"
    };
    let body_arg = if argc > 2 => {
        console::args::get(2)
    } else => {
        ""
    };
    let body = if body_arg == "-" => {
        console::stdin::read_all()
    } else => {
        body_arg
    };
    let verify_arg = if argc > 3 => {
        console::args::get(3)
    } else => {
        "true"
    };
    let verify_tls = verify_arg != "false" && verify_arg != "0" && verify_arg != "off";

    let exchange = http::exchange::new();
    http::exchange::set_target(exchange, host, port);
    http::exchange::set_scheme(exchange, "https");
    http::exchange::set_method(exchange, method);
    http::exchange::set_version(exchange, "3");
    if body != "" {
        http::exchange::set_body(exchange, body);
    }

    let session = tls::session::from_socket(exchange);
    if !verify_tls {
        tls::session::set_verify(session, false);
    }

    http::exchange::send(exchange);

    console::stdout::write("http-version=" + http::exchange::get_http_version(exchange) + "\n");
    console::stdout::write("alpn=" + tls::session::get_alpn(session) + "\n");

    let content_type = http::exchange::get_header(exchange, "content-type");
    if content_type != "" {
        console::stdout::write("content-type=" + content_type + "\n");
    }

    console::stdout::write("\n");
    console::stdout::write(http::exchange::get_body(exchange));
    console::stdout::write("\n");
    console::stdout::flush();
}
