use http;
use io;
use runtime;
use tcp;

let target = http::request::get_header("x-upstream-target");

if target == "" {
    http::response::set_status(400);
    http::response::set_body("missing x-upstream-target");
    runtime::exit();
}

// Start the upstream exchange and mirror the SSE response head.
let upstream = http::exchange::default_upstream();
http::exchange::set_target(upstream, target);

let status = http::exchange::get_status(upstream);
http::response::set_status(status);

let content_type = http::exchange::get_header(upstream, "content-type");
if content_type != "" {
    http::response::set_header("content-type", content_type);
}
http::response::set_header("x-sse-mutated", "true");

// Read the upstream SSE stream line-by-line so event boundaries stay visible.
let downstream = tcp::stream::downstream();

let mut event = "";

while !http::exchange::body::eof(upstream) {
    let line = io::read_line(upstream);
    if line == "" {
        if event != "" {
            tcp::stream::write(downstream, event + "\n");
            event = "";
        }
    } else {
        event = event + line + " [mutated]\n";
    }
}

if event != "" {
    tcp::stream::write(downstream, event + "\n");
}
