use http;
use proxy;

// Forward requests after optionally rewriting the downstream body chunk-by-chunk.
let upstream_host = "127.0.0.1";
let upstream_port = 18081;
let upstream_path = "/transform";

let exchange = http::exchange::default_upstream();
http::exchange::set_target(exchange, upstream_host, upstream_port);
http::exchange::set_path(exchange, upstream_path);

if http::request::get_header("Chunk-Transform") != "" {
    // Consume the request stream incrementally and annotate each chunk before upload.
    let mut transformed = "";
    while !http::request::body::eof() {
        transformed = transformed + http::request::body::next_chunk(3) + "#";
    }
    http::exchange::set_body(exchange, transformed);
    http::response::set_header("x-request-stream", "true");
} else {
    // Or forward the buffered request body unchanged.
    http::exchange::set_body(exchange, http::request::get_body());
    http::response::set_header("x-request-stream", "false");
}

// Forward the downstream response natively after staging the rewritten upstream request body.
let downstream = proxy::stream::downstream();
let upstream_stream = proxy::stream::exchange(exchange);
let proxy_status = proxy::forward(downstream, upstream_stream);
http::response::set_header("x-proxy-status", proxy_status);
