use http;
use proxy;

// Minimal forwarding sample wired to a fixed local upstream fixture.
let upstream_host = "127.0.0.1";
let upstream_port = 18080;
let upstream_path = "/sample";

let exchange = http::exchange::default_upstream();
http::exchange::set_target(exchange, upstream_host, upstream_port);
http::exchange::set_path(exchange, upstream_path);

if http::request::get_header("Streaming") != "" {
    // Accessing the response metadata/body implicitly executes the outbound exchange.
    let upstream_status = http::exchange::get_status(exchange);
    let content_type = http::exchange::get_header(exchange, "content-type");
    if content_type != "" {
        http::response::set_header("content-type", content_type);
    }
    http::response::set_status(upstream_status);

    // Read the response incrementally to make streaming behavior visible to the caller.
    let mut streamed = "";
    while !http::exchange::body::eof(exchange) {
        streamed = streamed + http::exchange::body::next_chunk(exchange, 2) + "A";
    }
    http::response::set_body(streamed);
} else {
    // Use the native forward path when the sample does not need to inspect each response chunk.
    let downstream = proxy::stream::downstream();
    let upstream_stream = proxy::stream::exchange(exchange);
    let proxy_status = proxy::forward(downstream, upstream_stream);
    http::response::set_header("x-proxy-status", proxy_status);
}
