use http;
use tls;

let origin = http::request::get_header("x-h2-origin");

if origin == "" {
    http::response::set_status(400);
    http::response::set_body("missing x-h2-origin");
} else {
    let slow = http::exchange::new();
    let fast = http::exchange::new();

    // These are two different outbound HTTP requests to the same origin.
    http::exchange::set_target(slow, origin + "/slow");
    http::exchange::set_method(slow, "POST");
    http::exchange::set_header(slow, "x-demo-request", "slow-request");
    http::exchange::set_body(slow, "alpha");

    http::exchange::set_target(fast, origin + "/fast");
    http::exchange::set_method(fast, "PUT");
    http::exchange::set_header(fast, "x-demo-request", "fast-request");
    http::exchange::set_body(fast, "beta");

    let slow_tls = tls::session::from_socket(slow);
    let fast_tls = tls::session::from_socket(fast);
    tls::session::set_verify(slow_tls, false);
    tls::session::set_verify(fast_tls, false);

    // Start both requests before consuming either body so they can share one HTTP/2 session.
    http::exchange::send(slow);
    http::exchange::send(fast);

    // Read the fast response while the slow response is still pending to make the overlap visible.
    let multiplex_fast_head = http::exchange::body::next_chunk(fast, 16);
    let multiplex_slow_head = http::exchange::body::next_chunk(slow, 16);
    let multiplex_fast_tail = http::exchange::body::next_chunk(fast, 128);
    let multiplex_slow_tail = http::exchange::body::next_chunk(slow, 128);
    let multiplex_fast_body = multiplex_fast_head + multiplex_fast_tail;
    let multiplex_slow_body = multiplex_slow_head + multiplex_slow_tail;

    http::response::set_header("x-multiplex-fast-version", http::exchange::get_http_version(fast));
    http::response::set_header("x-multiplex-slow-version", http::exchange::get_http_version(slow));
    http::response::set_header("x-multiplex-fast-alpn", tls::session::get_alpn(fast_tls));
    http::response::set_header("x-multiplex-slow-alpn", tls::session::get_alpn(slow_tls));
    http::response::set_header(
        "x-multiplex-fast-eof",
        if http::exchange::body::eof(fast) => { "true" } else => { "false" }
    );
    http::response::set_header(
        "x-multiplex-slow-eof",
        if http::exchange::body::eof(slow) => { "true" } else => { "false" }
    );

    let reused = http::exchange::new();
    http::exchange::set_target(reused, origin + "/reuse");
    http::exchange::set_method(reused, "PATCH");
    http::exchange::set_header(reused, "x-demo-request", "reuse-request");
    http::exchange::set_body(reused, "gamma");

    let reused_tls = tls::session::from_socket(reused);
    tls::session::set_verify(reused_tls, false);

    // This later third request should reuse that healthy HTTP/2 session.
    http::exchange::send(reused);

    let reused_head = http::exchange::body::next_chunk(reused, 16);
    let reused_tail = http::exchange::body::next_chunk(reused, 128);
    let reused_body = reused_head + reused_tail;

    http::response::set_header("x-reuse-version", http::exchange::get_http_version(reused));
    http::response::set_header("x-reuse-alpn", tls::session::get_alpn(reused_tls));
    http::response::set_header(
        "x-reuse-eof",
        if http::exchange::body::eof(reused) => { "true" } else => { "false" }
    );
    http::response::set_header("x-sample-pattern", "two-requests-multiplex-then-reuse");
    http::response::set_body(
        "multiplex:" + multiplex_fast_body + "|" + multiplex_slow_body + ";reuse:" + reused_body
    );
}
