use http;
use runtime;
use tcp;
use tls;

// Run this under pd-edge-http-proxy with:
// - --proxy-addr for the plain HTTP listener
// - --https-addr for the HTTPS/TLS listener
//
// The plain HTTP listener invokes this program directly in HTTP semantics.
// The HTTPS listener invokes it first in raw transport mode, before HTTP parsing.
// On that path:
// - plaintext HTTP is attached directly
// - TLS is accepted and then attached to the HTTP stack
let downstream = tcp::stream::downstream();

if http::request::get_scheme() == "tcp" {
    let prefix = tcp::stream::peek(downstream, 4);
    if prefix == "GET " || prefix == "POST" || prefix == "HEAD" ||
        prefix == "PUT " || prefix == "PATC" || prefix == "DELE" ||
        prefix == "OPTI" || prefix == "PRI " {
        http::downstream::attach_transport();
    } else {
        let session = tls::session::from_socket(downstream);
        tls::session::set_alpn(session, "h2,http/1.1");
        if tls::session::handshake(session) {
            http::downstream::attach_transport();
        } else {
            tcp::stream::close(downstream);
            runtime::exit();
        }
    }
}

http::response::set_status(201);
http::response::set_body(
    http::request::get_method() + "|" +
    http::request::get_path_with_query() + "|" +
    http::request::get_body()
);
http::response::set_header("x-request-scheme", http::request::get_scheme());
http::response::set_header("x-request-version", http::request::get_http_version());
