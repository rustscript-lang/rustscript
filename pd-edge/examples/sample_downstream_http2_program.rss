use http;

// Echo basic request metadata and tag HTTP/2 requests differently from the fallback path.
let version = http::request::get_http_version();
let path = http::request::get_path_with_query();
let body = http::request::get_body();

http::response::set_header("x-request-version", version);
http::response::set_header("x-request-method", http::request::get_method());
http::response::set_header("x-request-host", http::request::get_host());

// Return a distinct status/body shape so callers can verify which downstream protocol was used.
if version == "2" {
    http::response::set_status(201);
    http::response::set_header("x-request-carrier", "http2");
    http::response::set_body("h2:" + path + "|" + body);
} else {
    http::response::set_status(200);
    http::response::set_header("x-request-carrier", "http1");
    http::response::set_body("fallback:" + path + "|" + body);
}
