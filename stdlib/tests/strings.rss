use super::rss::strings::{contains, equals, is_empty, replace, split, trim};

assert(equals("rustscript", "rustscript"));
assert(equals("rustscript", "vm") == false);
assert(is_empty(""));
assert(is_empty("rustscript") == false);

assert(("hello").length == 5);
assert(contains("hello", "ell"));
assert(contains("hello", "zzz") == false);
assert(equals(trim("  rustscript\n"), "rustscript"));
assert(equals(replace("go gopher go", "go", "rs"), "rs rspher rs"));
assert(equals(
    string_replace_literal("%27x%20y+z", ["%27", "%20", "+"], ["'", " ", " "]),
    "'x y z"
));

let mut parts = split("a,b,c", ",");
assert(parts.length == 3);
assert(equals(parts[0], "a"));
assert(equals(parts[2], "c"));

let mut chars = split("ab", "");
assert(chars.length == 2);
assert(equals(chars[0], "a"));
assert(equals(chars[1], "b"));
