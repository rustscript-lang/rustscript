use self::crypto::aes_128_cbc as aes;

use bytes;

let key = "2b7e151628aed2a6abf7158809cf4f3c";
let iv = "000102030405060708090a0b0c0d0e0f";
let plaintext = "6bc1bee22e409f96e93d7e117393172a";

let ciphertext = aes::encrypt_cbc_hex(plaintext, key, iv);
let decrypted = aes::decrypt_cbc_hex(ciphertext, key, iv);
let ciphertext_bytes = bytes::from_hex(ciphertext);

assert(decrypted == plaintext);
assert(bytes::to_hex(ciphertext_bytes) == ciphertext);

ciphertext[0:32];
