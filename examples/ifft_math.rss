use math;

struct ComplexSignal {
    re: [float],
    im: [float]
}

fn nearly_equal(lhs: number, rhs: number) -> bool {
    math::abs(lhs - rhs) < 0.000001
}

fn nearly_zero(value: number) -> bool {
    nearly_equal(value, 0.0)
}

fn clean(value: float) -> float {
    let mut out = value;
    if nearly_zero(value) {
        out = 0.0;
    }
    out
}

fn exact_log2(value: int) -> int {
    let mut bits = 0;
    let mut remaining = value;
    let mut valid = remaining > 0;
    while remaining > 1 {
        if remaining % 2 == 0 {
            remaining = remaining / 2;
            bits = bits + 1;
        } else {
            valid = false;
            remaining = 1;
        }
    }
    let mut out =-1;
    if valid {
        out = bits;
    }
    out
}

fn reverse_bits(index: int, bit_count: int) -> int {
    let mut out = 0;
    let mut value = index;
    let mut i = 0;
    while i < bit_count {
        out = out * 2 + value % 2;
        value = value / 2;
        i = i + 1;
    }
    out
}

fn ifft(freq_re: [float], freq_im: [float]) -> ComplexSignal {
    let n = freq_re.length;
    assert(n == freq_im.length);

    let bit_count = exact_log2(n);
    assert(bit_count >= 0);

    let mut out_re: [float] = [];
    let mut out_im: [float] = [];
    let mut i = 0;
    while i < n {
        let j = reverse_bits(i, bit_count);
        out_re[i] = freq_re[j];
        out_im[i] = freq_im[j];
        i = i + 1;
    }

    let mut size = 2;
    while size <= n {
        let mut half = size / 2;
        let mut j = 0;
        while j < half {
            let angle = 2.0 * math::pi() * j / size;
            let wr = math::cos(angle);
            let wi = math::sin(angle);
            let mut k = j;
            while k < n {
                let pair = k + half;
                let even_re =(&out_re)[k];
                let even_im =(&out_im)[k];
                let odd_re =(&out_re)[pair];
                let odd_im =(&out_im)[pair];
                let t_re = odd_re * wr - odd_im * wi;
                let t_im = odd_re * wi + odd_im * wr;

                out_re[k] = even_re + t_re;
                out_im[k] = even_im + t_im;
                out_re[pair] = even_re - t_re;
                out_im[pair] = even_im - t_im;

                k = k + size;
            }
            j = j + 1;
        }
        size = size * 2;
    }

    let scale = 1.0 / n;
    i = 0;
    while i < n {
        out_re[i] = clean(out_re[i] * scale);
        out_im[i] = clean(out_im[i] * scale);
        i = i + 1;
    }

    let out: ComplexSignal = {re: out_re, im: out_im};
    out
}

// These bins are the forward DFT of [1, 2, 3, 4].
let spectrum_re = [10.0,-2.0,-2.0,-2.0];
let spectrum_im = [0.0, 2.0, 0.0,-2.0];

let signal = ifft(spectrum_re, spectrum_im);
let signal_re = signal.re;
let signal_im = signal.im;

let sample0 = signal_re[0];
let sample1 = signal_re[1];
let sample2 = signal_re[2];
let sample3 = signal_re[3];

let imag0 = signal_im[0];
let imag1 = signal_im[1];
let imag2 = signal_im[2];
let imag3 = signal_im[3];

assert(nearly_equal(sample0, 1.0));
assert(nearly_equal(sample1, 2.0));
assert(nearly_equal(sample2, 3.0));
assert(nearly_equal(sample3, 4.0));

assert(nearly_zero(imag0));
assert(nearly_zero(imag1));
assert(nearly_zero(imag2));
assert(nearly_zero(imag3));

print(math::round(sample0));
print(math::round(sample1));
print(math::round(sample2));
print(math::round(sample3));
